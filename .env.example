# Database - Supabase (Session Pooler)
DATABASE_URL="postgresql://postgres.xxx:xxx@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Authentication
JWT_SECRET="your-jwt-secret-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI - Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Google Drive Service Account（從 Google Cloud Console 建立服務帳號並下載金鑰 JSON）
GOOGLE_SERVICE_ACCOUNT_KEY="..."

# Google Drive 根資料夾 ID（在 Google Drive 建立「註冊文件」資料夾，複製其 ID）
GOOGLE_DRIVE_ROOT_FOLDER_ID="..."

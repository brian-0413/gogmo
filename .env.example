# Database - Supabase (Session Pooler)
DATABASE_URL="postgresql://postgres.xxx:xxx@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Authentication
JWT_SECRET="your-jwt-secret-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI - Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Google Drive Service Account（從 Google Cloud Console 建立服務帳號並下載金鑰 JSON）
GOOGLE_SERVICE_ACCOUNT_KEY="..."

# Google Drive 資料夾 ID（在 Google Drive 建立資料夾，複製其 ID）
GOOGLE_DRIVE_ROOT_FOLDER_ID="..."
GOOGLE_DRIVE_DRIVER_FOLDER_ID="..."   # 司機文件上傳資料夾
GOOGLE_DRIVE_DISPATCHER_FOLDER_ID="..." # 派單方文件上傳資料夾

# Google Apps Script Web App URL（部署 Apps Script 並設為「Anyone」後的 exec URL）
GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/AKfycbx.../exec"

# PAYUNi 信用卡 API（藍新金流）
PAYU_MER_ID="your-merchant-id"
PAYU_HASH_KEY="your-hash-key"
PAYU_HASH_IV="your-hash-iv"
PAYU_ENV="production"  # "production" 或 "sandbox"

# Email - Resend
RESEND_API_KEY="re_your-api-key"

# Cron API 密鑰（用於驗證 cron job 呼叫）
CRON_SECRET="your-cron-secret"

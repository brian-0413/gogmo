// Prisma schema for Airport Dispatch Platform
// Version: 1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== Enums ==============

enum UserRole {
  DRIVER
  DISPATCHER
  ADMIN
}

enum DriverStatus {
  ONLINE
  OFFLINE
  BUSY
}

enum OrderStatus {
  PENDING      // 待審核（草稿）
  PUBLISHED    // 已發布（可見於首頁）
  ASSIGNED     // 已指派司機
  ACCEPTED     // 司機已接單
  IN_PROGRESS  // 行程開始（司機按開始）
  ARRIVED      // 已抵達（司機按抵達）
  PICKED_UP    // 乘客已上車（司機按客上）
  COMPLETED    // 已完成
  CANCELLED    // 已取消
}

enum TransactionType {
  RIDE_FARE      // 車資收入
  PLATFORM_FEE    // 平台費支出
  RECHARGE        // 儲值
  WITHDRAW        // 提領
}

enum TransactionStatus {
  PENDING  // 待結算
  SETTLED   // 已結算
}

enum TransferStatus {
  PENDING_SQUAD       // 等待隊友接
  PENDING_DISPATCHER  // 等待派單方確認
  APPROVED            // 已完成
  REJECTED            // 派單方拒絕
  CANCELLED           // 已取消
  EXPIRED             // 過期（行程鎖定）
}

enum AccountStatus {
  PENDING_VERIFICATION
  PENDING_REVIEW
  ACTIVE
  REJECTED
}

enum DispatcherTier {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum VerificationStatus {
  PENDING
  PHONE_VERIFIED
  FULLY_VERIFIED
  REJECTED
  SUSPENDED
}

// === 車型系統（與 src/lib/vehicle 同步） ===

enum VehicleType {
  SEDAN_5  // 5 人座（轎車）
  SUV_5    // 5 人座休旅（含 7 人座 SUV）
  MPV_7    // 7 人座 MPV
  VAN_9    // 9 人座
  CUSTOM   // 自訂車款
}

enum RequirementLevel {
  EXACT  // 必須是這個車型
  MIN    // 最低需求，可派更高等級
  ANY    // 任意車型
}

enum PlateType {
  RENTAL  // R 牌（租賃車）
  TAXI    // T 牌（計程車）
}

// ============== Models ==============

model Squad {
  id        String        @id @default(cuid())
  name      String
  maxMembers Int          @default(10)
  founderId String        // 建立者（司機）
  founder   Driver        @relation("SquadFounder", fields: [founderId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime     @updatedAt

  members   SquadMember[]
  invites   SquadInvite[]
  transfers OrderTransfer[]

  @@map("squads")
}

model SquadMember {
  id        String   @id @default(cuid())
  squadId   String
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  driverId  String   @unique  // 一個司機只能在一個小隊
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([squadId, driverId])
  @@index([squadId])
  @@map("squad_members")
}

model SquadInvite {
  id        String   @id @default(cuid())
  squadId   String
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  driverId  String   // 被邀請司機
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending / accepted / rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([squadId])
  @@map("squad_invites")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String   @unique
  role             UserRole
  emailVerified    Boolean        @default(false)
  emailVerifyToken String?
  accountStatus    AccountStatus  @default(PENDING_VERIFICATION)
  rejectReason     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Tier & Quota System (派單方用，司機/管理員預設 BASIC)
  tier             DispatcherTier    @default(BASIC)
  tierExpiresAt    DateTime?
  dailyOrderCount  Int               @default(0)
  dailyCountResetAt DateTime         @default(now())

  // Verification System
  realName             String?
  nationalIdHash       String?
  taxId                String?
  phoneVerifiedAt      DateTime?
  emailVerifiedAt      DateTime?
  lineId               String?
  verificationStatus   VerificationStatus @default(PENDING)
  verifiedAt           DateTime?

  // Relations
  driver     Driver?
  dispatcher Dispatcher?
  admin      Admin?
  documents  UserDocument[]

  @@map("users")
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Driver {
  id              String       @id @default(uuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  licensePlate    String       // 車牌
  vehicleType     VehicleType  @default(SEDAN_5)
  plateType       PlateType    @default(RENTAL)
  carColor        String       // 車色
  carBrand        String?      // 車廠/品牌（如：TOYOTA）
  carModel        String?      // 車型/型號（如：CAMRY）
  balance         Int          @default(0) // 點數餘額（整數，1點=1元）
  status          DriverStatus @default(OFFLINE)
  currentLat      Float?
  currentLng      Float?
  lastLocationAt  DateTime?
  bankCode        String?      // 銀行代碼
  bankAccount     String?      // 銀行帳號
  isPremium        Boolean      @default(false) // Premium 司機可使用小車頭發單功能
  lastSseCheckAt   DateTime?   // SSE 端點追蹤的最後檢查時間（跨實例安全）
  lastConflictAcceptAt DateTime? // 衝突接單冷卻時間（防止連續繞過警告）
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  orders          Order[]
  transactions    Transaction[]
  squadMembership SquadMember?
  foundedSquads   Squad[]         @relation("SquadFounder")
  transfersOut    OrderTransfer[] @relation("TransferFrom")
  transfersIn     OrderTransfer[] @relation("TransferTo")
  squadInvites    SquadInvite[]
  topups          Topup[]
  pricing         DriverPricing[]
  customers       DriverCustomer[]
  messageThreads  MessageThread[]

  @@map("drivers")
}

model Dispatcher {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String   // 公司/車隊名稱
  taxId           String?  // 統一編號
  contactPhone    String?  // 聯絡電話（獨立於 User.phone）
  commissionRate  Float    @default(0) // 抽成比例
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Duplicate order handling preference
  duplicateHandling String @default("auto_merge") // auto_merge / warn_and_keep / ask_user

  // Relations
  orders          Order[]
  messageThreads  MessageThread[]
  preference      DispatcherPreference?

  @@map("dispatchers")
}

model Order {
  id              String      @id @default(uuid())
  orderDate       String      @default("")   // YYYYMMDD format for daily sequence
  orderSeq        Int         @default(0)   // Daily sequence 0001-9999
  dispatcherId     String
  dispatcher       Dispatcher  @relation(fields: [dispatcherId], references: [id])

  // Driver assignment (null = 待接單)
  driverId        String?
  driver          Driver?     @relation(fields: [driverId], references: [id])

  status          OrderStatus @default(PENDING)

  // 乘客資訊
  passengerName   String
  passengerPhone  String

  // 航班資訊
  flightNumber    String    @default("")

  // 上車地點
  pickupLocation  String      // 地點名（如：桃園機場第一航廈）
  pickupAddress   String      // 完整地址
  pickupLat       Float?
  pickupLng       Float?

  // 下車地點
  dropoffLocation String
  dropoffAddress  String
  dropoffLat      Float?
  dropoffLng      Float?

  // 乘客資訊
  passengerCount  Int         @default(1)
  luggageCount    Int         @default(0)

  // 時間與價格
  scheduledTime   DateTime    // 預定時間
  price           Int          // 價格（整數）

  // 接送種類與車型要求
  type             String      @default("pending") // pickup / dropoff / transfer / charter / pending
  vehicleType      VehicleType?
  vehicleRequirement RequirementLevel @default(EXACT)
  customVehicleNote String?
  allowTaxiPlate   Boolean     @default(false)   // 是否允許 T 牌司機接單

  // 解析後備註（原文保留）
  notes           String?

  // AI 解析用
  rawText         String?     // 完整原始訊息
  parsedData      Json?       // AI解析後的結構化資料

  note            String?      // 派單方自填備註

  // 肯驛系統
  kenichiRequired Boolean     @default(false) // 是否需要肯驛系統
  isSelfPublish    Boolean     @default(false) // 司機自助發單
  isPremium         Boolean     @default(false) // Premium 加價單

  // 轉帳狀態
  transferStatus   String     @default("pending") // pending / completed

  // 加價系統
  originalPrice    Int?       // 建立時的原始價格（永不變）
  currentPrice     Int?       // 現價 = originalPrice + 累積加價
  isSurge          Boolean    @default(false)
  surgeEnabled     Boolean    @default(true)      // false = 低價陷阱，永久禁用加價
  surgeCount       Int        @default(0)         // 已加價次數，上限 3

  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?   // 完成時間
  startedAt       DateTime?   // 司機按「開始」
  arrivedAt       DateTime?   // 司機按「抵達」
  pickedUpAt      DateTime?   // 司機按「客上」

  // Relations
  transactions     Transaction[]
  isLocked        Boolean         @default(false)
  isQROrder       Boolean         @default(false)
  originalDriverId String?         // 原司機 ID（QR單外派後仍可追溯）
  qrPrice         Int?            // QR單的報價（建立時鎖定）

  transfers       OrderTransfer[]
  surgeHistory    OrderSurgeHistory[]

  @@index([status])
  @@index([isLocked])
  @@index([driverId])
  @@index([dispatcherId])
  @@index([scheduledTime])
  @@index([dispatcherId, status])
  @@index([scheduledTime, status])
  @@map("orders")
}

model Transaction {
  id          String            @id @default(uuid())
  orderId     String?
  order       Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  driverId    String
  driver      Driver            @relation(fields: [driverId], references: [id])

  amount      Int               // 金額（正=收入，負=支出）
  type        TransactionType
  status      TransactionStatus @default(PENDING)

  description String?          // 描述
  createdAt   DateTime         @default(now())
  settledAt   DateTime?        // 結算時間

  topupId      String?
  topup        Topup?           @relation(fields: [topupId], references: [id])

  @@index([driverId])
  @@index([status])
  @@index([driverId, status])
  @@index([orderId])
  @@index([topupId])
  @@map("transactions")
}

model UserDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // DRIVER_LICENSE / VEHICLE_REGISTRATION / INSURANCE / ID_CARD / BUSINESS_REGISTRATION
  fileUrl   String?  // 改存 Google Drive 分享連結（webViewLink）
  driveFileId   String?  // Google Drive 檔案 ID
  driveFolderId String? // Google Drive 資料夾 ID
  fileName  String   // 原始檔案名稱
  mimeType  String   // image/jpeg / image/png / application/pdf
  sizeBytes Int      // 檔案大小（位元組）
  status    String   @default("PENDING")  // PENDING / APPROVED / REJECTED
  uploadFailed Boolean @default(false)   // 上傳失敗標記
  expiryDate DateTime?                   // 證件到期日（行照/駕照/保險）
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("user_documents")
}

model OrderTransfer {
  id            String          @id @default(cuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id])
  fromDriverId  String
  fromDriver    Driver          @relation("TransferFrom", fields: [fromDriverId], references: [id])
  toDriverId    String?         // null = 還在等隊友接
  toDriver      Driver?         @relation("TransferTo", fields: [toDriverId], references: [id])
  squadId       String
  squad         Squad           @relation(fields: [squadId], references: [id])
  reason        String?
  transferFee   Int             // 轉單費用（訂單金額 * 3%，在接手成功後扣）
  bonusPoints   Int             @default(0)  // bonus 點數
  status        TransferStatus @default(PENDING_SQUAD)
  dispatcherNote String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orderId])
  @@index([fromDriverId])
  @@index([toDriverId])
  @@index([squadId])
  @@index([status])
  @@map("order_transfers")
}

model Topup {
  id            String    @id @default(cuid())
  driverId      String
  driver        Driver    @relation(fields: [driverId], references: [id])
  amount        Int
  method        String    // "credit" | "transfer"
  status        String    @default("pending") // "pending" | "paid" | "cancelled"
  payuniTradeNo String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  transactions  Transaction[]

  @@index([driverId])
  @@map("topups")
}

model DriverPricing {
  id          String   @id @default(cuid())
  driverId    String
  vehicleType VehicleType
  price       Int      // NT$
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, vehicleType])
  @@map("driver_pricing")
}

model DriverCustomer {
  id               String    @id @default(cuid())
  driverId         String
  name             String
  phone            String
  commonPickup     String?
  commonDropoff    String?
  preferredVehicle String?   // "small" | "suv" | "van9"
  notes            String?
  createdAt        DateTime  @default(now())
  lastOrderAt      DateTime?
  driver           Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, phone])
  @@index([driverId])
  @@map("driver_customers")
}

// ============== Messaging ==============

model MessageThread {
  id            String    @id @default(cuid())
  dispatcherId  String
  dispatcher    Dispatcher @relation(fields: [dispatcherId], references: [id])
  driverId      String
  driver        Driver    @relation(fields: [driverId], references: [id])
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages     Message[]
  participants MessageParticipant[]

  @@unique([dispatcherId, driverId])
  @@index([driverId])
  @@index([dispatcherId])
  @@map("message_threads")
}

model MessageParticipant {
  id        String       @id @default(cuid())
  threadId  String
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String       // either driver.userId or dispatcher.userId
  role      UserRole     // DRIVER or DISPATCHER
  lastReadAt DateTime?   // last time user opened this thread
  createdAt DateTime      @default(now())

  @@unique([threadId, userId])
  @@index([userId])
  @@map("message_participants")
}

model Message {
  id        String    @id @default(cuid())
  threadId  String
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String    // userId of the sender
  senderRole UserRole  // DRIVER or DISPATCHER
  content   String
  isRead   Boolean   @default(false)
  isSystem Boolean   @default(false) // system-generated messages (e.g., order status changes)
  createdAt DateTime  @default(now())

  @@index([threadId])
  @@index([senderId])
  @@map("messages")
}

// ============== Surge Pricing ==============

model OrderSurgeHistory {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  previousPrice Int
  surgeAmount   Int
  newPrice      Int
  surgedAt      DateTime @default(now())
  surgedBy      String   // dispatcher userId

  @@index([orderId])
  @@map("order_surge_history")
}

model RegionPriceStats {
  id          String   @id @default(cuid())
  region      String
  timeSlot    String
  airport     String?
  vehicleType VehicleType?
  avgPrice    Int
  sampleSize  Int
  updatedAt   DateTime @updatedAt

  @@unique([region, timeSlot, airport, vehicleType])
  @@map("region_price_stats")
}

// ============== Dispatcher Preferences ==============

model DispatcherPreference {
  id                 String   @id @default(cuid())
  dispatcherId       String   @unique
  dispatcher         Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)
  defaultVehicleType String?
  defaultLicenseType String?
  defaultPrice       Int?
  defaultAirport     String?
  driverRequirements Json?
  paymentMethod      String?
  batchPriceMode     String   @default("off") // inherit / override / off
  updatedAt          DateTime @updatedAt

  @@map("dispatcher_preferences")
}

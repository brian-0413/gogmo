// Prisma schema for Airport Dispatch Platform
// Version: 1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== Enums ==============

enum UserRole {
  DRIVER
  DISPATCHER
  ADMIN
}

enum DriverStatus {
  ONLINE
  OFFLINE
  BUSY
}

enum OrderStatus {
  PENDING      // 待審核（草稿）
  PUBLISHED    // 已發布（可見於首頁）
  ASSIGNED     // 已指派司機
  ACCEPTED     // 司機已接單
  IN_PROGRESS  // 行程開始（司機按開始）
  ARRIVED      // 已抵達（司機按抵達）
  PICKED_UP    // 乘客已上車（司機按客上）
  COMPLETED    // 已完成
  CANCELLED    // 已取消
}

enum TransactionType {
  RIDE_FARE      // 車資收入
  PLATFORM_FEE    // 平台費支出
  RECHARGE        // 儲值
  WITHDRAW        // 提領
}

enum TransactionStatus {
  PENDING  // 待結算
  SETTLED   // 已結算
}

enum TransferStatus {
  PENDING_SQUAD       // 等待隊友接
  PENDING_DISPATCHER  // 等待派單方確認
  APPROVED            // 已完成
  REJECTED            // 派單方拒絕
  CANCELLED           // 已取消
  EXPIRED             // 過期（行程鎖定）
}

enum AccountStatus {
  PENDING_VERIFICATION
  PENDING_REVIEW
  ACTIVE
  REJECTED
}

// ============== Models ==============

model Squad {
  id        String        @id @default(cuid())
  name      String
  maxMembers Int          @default(10)
  founderId String        // 建立者（司機）
  founder   Driver        @relation("SquadFounder", fields: [founderId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime     @updatedAt

  members   SquadMember[]
  invites   SquadInvite[]
  transfers OrderTransfer[]

  @@map("squads")
}

model SquadMember {
  id        String   @id @default(cuid())
  squadId   String
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  driverId  String   @unique  // 一個司機只能在一個小隊
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([squadId, driverId])
  @@index([squadId])
  @@map("squad_members")
}

model SquadInvite {
  id        String   @id @default(cuid())
  squadId   String
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  driverId  String   // 被邀請司機
  driver    Driver   @relation(fields: [driverId], references: [id])
  status    String   @default("pending") // pending / accepted / rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([squadId])
  @@map("squad_invites")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String
  role             UserRole
  emailVerified    Boolean        @default(false)
  emailVerifyToken String?
  accountStatus    AccountStatus  @default(PENDING_VERIFICATION)
  rejectReason     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  driver     Driver?
  dispatcher Dispatcher?
  admin      Admin?
  documents  UserDocument[]

  @@map("users")
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Driver {
  id              String       @id @default(uuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  licensePlate    String       // 車牌
  carType         String       // 車型（如：轎車、SUV、福祉車）
  carColor        String       // 車色
  carBrand        String?      // 車廠/品牌（如：TOYOTA）
  carModel        String?      // 車型/型號（如：CAMRY）
  balance         Int          @default(0) // 點數餘額（整數，1點=1元）
  status          DriverStatus @default(OFFLINE)
  currentLat      Float?
  currentLng      Float?
  lastLocationAt  DateTime?
  bankCode        String?      // 銀行代碼
  bankAccount     String?      // 銀行帳號
  isPremium        Boolean      @default(false) // Premium 司機可使用小車頭發單功能
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  orders          Order[]
  transactions    Transaction[]
  squadMembership SquadMember?
  foundedSquads   Squad[]         @relation("SquadFounder")
  transfersOut    OrderTransfer[] @relation("TransferFrom")
  transfersIn     OrderTransfer[] @relation("TransferTo")
  squadInvites    SquadInvite[]

  @@map("drivers")
}

model Dispatcher {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String   // 公司/車隊名稱
  taxId           String?  // 統一編號
  contactPhone    String?  // 聯絡電話（獨立於 User.phone）
  commissionRate  Float    @default(0) // 抽成比例
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  orders          Order[]

  @@map("dispatchers")
}

model Order {
  id              String      @id @default(uuid())
  orderDate       String      @default("")   // YYYYMMDD format for daily sequence
  orderSeq        Int         @default(0)   // Daily sequence 0001-9999
  dispatcherId     String
  dispatcher       Dispatcher  @relation(fields: [dispatcherId], references: [id])

  // Driver assignment (null = 待接單)
  driverId        String?
  driver          Driver?     @relation(fields: [driverId], references: [id])

  status          OrderStatus @default(PENDING)

  // 乘客資訊
  passengerName   String
  passengerPhone  String

  // 航班資訊
  flightNumber    String    @default("")

  // 上車地點
  pickupLocation  String      // 地點名（如：桃園機場第一航廈）
  pickupAddress   String      // 完整地址
  pickupLat       Float?
  pickupLng       Float?

  // 下車地點
  dropoffLocation String
  dropoffAddress  String
  dropoffLat      Float?
  dropoffLng      Float?

  // 乘客資訊
  passengerCount  Int         @default(1)
  luggageCount    Int         @default(0)

  // 時間與價格
  scheduledTime   DateTime    // 預定時間
  price           Int          // 價格（整數）

  // 接送種類與車型要求
  type            String      @default("pending") // pickup / dropoff / transfer / charter / pending
  vehicle         String      @default("pending") // small / suv / van9 / any / any_r / pending
  plateType       String      @default("any")     // R / T / any

  // 解析後備註（原文保留）
  notes           String?

  // AI 解析用
  rawText         String?     // 完整原始訊息
  parsedData      Json?       // AI解析後的結構化資料

  note            String?      // 派單方自填備註

  // 肯驛系統
  kenichiRequired Boolean     @default(false) // 是否需要肯驛系統
  isSelfPublish    Boolean     @default(false) // 司機自助發單

  // 轉帳狀態
  transferStatus   String     @default("pending") // pending / completed

  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?   // 完成時間
  startedAt       DateTime?   // 司機按「開始」
  arrivedAt       DateTime?   // 司機按「抵達」
  pickedUpAt      DateTime?   // 司機按「客上」

  // Relations
  transactions     Transaction[]
  isLocked        Boolean         @default(false)
  transfers       OrderTransfer[]

  @@index([status])
  @@index([driverId])
  @@index([dispatcherId])
  @@index([scheduledTime])
  @@index([dispatcherId, status])
  @@index([scheduledTime, status])
  @@map("orders")
}

model Transaction {
  id          String            @id @default(uuid())
  orderId     String?
  order       Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  driverId    String
  driver      Driver            @relation(fields: [driverId], references: [id])

  amount      Int               // 金額（正=收入，負=支出）
  type        TransactionType
  status      TransactionStatus @default(PENDING)

  description String?          // 描述
  createdAt   DateTime         @default(now())
  settledAt   DateTime?        // 結算時間

  @@index([driverId])
  @@index([status])
  @@index([driverId, status])
  @@index([orderId])
  @@map("transactions")
}

model UserDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // DRIVER_LICENSE / VEHICLE_REGISTRATION / INSURANCE / ID_CARD / BUSINESS_REGISTRATION
  fileUrl   String?  // 改存 Google Drive 分享連結（webViewLink）
  driveFileId   String?  // Google Drive 檔案 ID
  driveFolderId String? // Google Drive 資料夾 ID
  fileName  String   // 原始檔案名稱
  mimeType  String   // image/jpeg / image/png / application/pdf
  sizeBytes Int      // 檔案大小（位元組）
  status    String   @default("PENDING")  // PENDING / APPROVED / REJECTED
  uploadFailed Boolean @default(false)   // 上傳失敗標記
  expiryDate DateTime?                   // 證件到期日（行照/駕照/保險）
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("user_documents")
}

model OrderTransfer {
  id            String          @id @default(cuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id])
  fromDriverId  String
  fromDriver    Driver          @relation("TransferFrom", fields: [fromDriverId], references: [id])
  toDriverId    String?         // null = 還在等隊友接
  toDriver      Driver?         @relation("TransferTo", fields: [toDriverId], references: [id])
  squadId       String
  squad         Squad           @relation(fields: [squadId], references: [id])
  reason        String?
  transferFee   Int             // 轉單費用（訂單金額 * 3%，在接手成功後扣）
  bonusPoints   Int             @default(0)  // bonus 點數
  status        TransferStatus @default(PENDING_SQUAD)
  dispatcherNote String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orderId])
  @@index([fromDriverId])
  @@index([toDriverId])
  @@index([squadId])
  @@index([status])
  @@map("order_transfers")
}
